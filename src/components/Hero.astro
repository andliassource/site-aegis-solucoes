---
import { Image } from 'astro:assets';
---
<section id="home" class="bg-white">
    <div class="container mx-auto px-6 py-20 md:py-32">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="text-center lg:text-left">
                <h1 class="text-4xl md:text-6xl font-extrabold text-aegis-dark leading-tight mb-6">
                    Sua empresa em conformidade, sempre.
                </h1>
                <p class="text-lg md:text-xl text-aegis-gray-500 mb-8">
                    A Aegis oferece um <strong>ERP/CRM modular com Inteligência Artificial</strong> para simplificar a conformidade tributária e governança, garantindo segurança e flexibilidade.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
                    <a href="#contato" class="bg-aegis-blue-500 text-white font-bold py-4 px-8 rounded-lg text-lg hover:bg-aegis-blue-600 transition-transform duration-300 transform hover:scale-105 inline-block">
                        Fale com um Especialista
                    </a>
                    <a href="https://app.aegissolucoes.dev.br" class="bg-green-500 text-white font-bold py-4 px-8 rounded-lg text-lg hover:bg-green-600 transition-transform duration-300 transform hover:scale-105 inline-block">
                        Testar Demo Grátis
                    </a>
                </div>
            </div>
            <div class="relative w-full max-w-lg mx-auto lg:mx-0 lg:max-w-none" x-data="{ activeSlide: 1, slides: [ { id: 1, image: '/images/img1.png', alt: 'Image 1' }, { id: 2, image: '/images/img2.png', alt: 'Image 2' } ] }" x-init="setInterval(() => { activeSlide = activeSlide === slides.length ? 1 : activeSlide + 1 }, 3000)">
                <div class="relative overflow-hidden rounded-lg shadow-2xl h-96">
                    <template x-for="slide in slides" :key="slide.id">
                        <div x-show="activeSlide === slide.id" class="absolute inset-0 transition-opacity duration-1000 ease-in-out">
                            <img :src="slide.image" class="block w-full h-full object-contain" :alt="slide.alt">
                        </div>
                    </template>
                </div>
            </div>
        </div>
    </div>
</section>